{
  "name": "book-db",
  "description": "Starter for your electron + sqlite application",
  "version": "1.0.0",
  "license": "MIT",
  "main": "dist/main.js",
  "build": {
    "files": [
      "dist/**/*",
      "app/**/*",
      "node_modules/**/*",
      "package.json"
    ]
  },
  "scripts": {
    "build": "npm run build:server && npm run build:ui",
    "build:server": "tsc",
    "build:ui": "vite build",
    "start": "npm run build && electron-forge start",
    "serve": "npm run build && node dist/server/standalone.js",
    "typecheck": "tsc --noEmit && tsc -p ui/tsconfig.json --noEmit",
    "test": "npm run typecheck",
    "release": "npm run make",
    "package": "npm run build && electron-forge package",
    "make": "npm run build && electron-forge make"
  },
  "devDependencies": {
    "@electron-forge/cli": "^6.4.2",
    "@electron-forge/maker-deb": "^6.4.2",
    "@electron-forge/maker-rpm": "^6.4.2",
    "@electron-forge/maker-squirrel": "^6.4.2",
    "@electron-forge/maker-zip": "^6.4.2",
    "@electron-forge/plugin-auto-unpack-natives": "^6.4.2",
    "@tailwindcss/vite": "^4.3.0",
    "@types/express": "^4.17.21",
    "@types/node": "^20.11.30",
    "@types/qrcode": "^1.5.6",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.2",
    "electron": "^26.1.0",
    "typescript": "^5.4.5",
    "vite": "^8.0.13"
  },
  "dependencies": {
    "@radix-ui/react-dialog": "^1.1.15",
    "@radix-ui/react-dropdown-menu": "^2.1.16",
    "@radix-ui/react-select": "^2.2.6",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "express": "^4.18.2",
    "jquery": "^3.7.0",
    "lucide-react": "^1.16.0",
    "pdf-lib": "^1.17.1",
    "qrcode": "^1.5.4",
    "react": "^19.2.6",
    "react-dom": "^19.2.6",
    "sqlite3": "^5.1.6",
    "tailwind-merge": "^3.6.0"
  },
  "config": {
    "forge": {
      "packagerConfig": {
        "icon": "/app/assets/icon.png",
        "asar": true,
        "extraResource": [
          "app/assets"
        ],
        "extraMetadata": {
          "main": "dist/main.js"
        }
      },
      "makers": [
        {
          "name": "@electron-forge/maker-squirrel",
          "config": {
            "name": "book-db",
            "authors": "Quiradon",
            "setupIcon": "app/assets/icon.png"
          }
        },
        {
          "name": "@electron-forge/maker-zip",
          "platforms": [
            "darwin"
          ]
        },
        {
          "name": "@electron-forge/maker-deb",
          "config": {}
        },
        {
          "name": "@electron-forge/maker-rpm",
          "config": {
            "options": {
              "name": "book-db",
              "productDescription": "A simple book database",
              "icon": "app/assets/icon.png"
            }
          }
        }
      ]
    }
  }
}
